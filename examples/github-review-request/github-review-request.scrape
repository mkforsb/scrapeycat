header("Authorization", "Bearer {1}")
header("User-Agent", "scrapeycat")
get("https://api.github.com/search/issues?q=is:pr+is:open+review-requested:@me")
store("$response")

jsonPath("$.items[0].title")
store("$title")

clear()
load("$response")
jsonPath("$.items[0].html_url")
store("$url")

effect("notify", {title="Review Requested", body=var("$title") .. "\n" .. var("$url"), appname="scrapeycat"})
